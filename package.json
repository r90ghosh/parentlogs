{
  "name": "thedadcenter",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "turbo run dev --filter=@tdc/web",
    "dev:mobile": "turbo run dev --filter=@tdc/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@tdc/web",
    "build:mobile": "turbo run build --filter=@tdc/mobile",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:reset": "supabase db reset",
    "db:generate-types": "supabase gen types typescript --project-id oeeeiquclwfpypojjigx > packages/shared/src/types/database.ts",
    "db:check-types": "./scripts/check-db-types.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "@tanstack/react-query": "5.91.2"
    }
  },
  "dependencies": {
    "@ungap/structured-clone": "^1.3.0"
  }
}
